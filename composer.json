{
    "name": "coolycow/laravel-dadata",
    "description": "Dadata API client for Laravel (https://dadata.ru)",
    "keywords": ["laravel", "dadata", "autocomplete", "suggest", "clean"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxim Kulikov",
            "email": "coolycow.com@gmail.com",
            "homepage": "https://coolycow.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.37|^9.17|^10.11|^11.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Coolycow\\Dadata\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Coolycow\\Dadata\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Coolycow\\Dadata\\DadataServiceProvider"
            ],
            "aliases": {
                "DadataSuggest": "Coolycow\\Dadata\\Facades\\DadataSuggest",
                "DadataClean": "Coolycow\\Dadata\\Facades\\DadataClean"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
